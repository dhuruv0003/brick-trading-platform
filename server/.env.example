# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/brickpro

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_COOKIE_EXPIRES_IN=7

# Client URL (for CORS) — Next.js dev server default
## The frontend origin(s) allowed to call this API (CORS). Comma-separate
## multiple values if you have more than one (e.g. a custom domain + the
## default vercel.app URL). Do not include a trailing slash.
## Note: any https://*.vercel.app origin is always allowed automatically
## (see app.js), to tolerate Vercel's per-deploy preview subdomains — this
## setting matters most for your real production domain.
CLIENT_URL=http://localhost:3000

# Email — sent via Brevo's HTTP API (not SMTP), since Render's free tier
# blocks outbound SMTP ports (25/465/587) but allows normal HTTPS (443).
# 1. Sign up free at https://www.brevo.com
# 2. Get your API key: Settings -> SMTP & API -> API Keys -> Generate a new API key
# 3. Verify a sender: Senders, Domains & Dedicated IPs -> Senders -> Add a sender
BREVO_API_KEY=
BREVO_SENDER_EMAIL=your_verified_sender@example.com
BREVO_SENDER_NAME=BrickPro

# Admin email for lead notifications
ADMIN_EMAIL=admin@brickpro.com

# WhatsApp Cloud API (Meta) — leave blank to disable WhatsApp notifications
# Get these from Meta for Developers -> your App -> WhatsApp -> API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v20.0
# Admin's own WhatsApp number to receive new-lead alerts (defaults to COMPANY_WHATSAPP below)
ADMIN_WHATSAPP=
# Optional: name of an approved WhatsApp message template for first-contact
# messages (required by Meta if the customer hasn't messaged you first).
# Leave blank to send plain text messages instead.
WHATSAPP_FALLBACK_TEMPLATE=

# OpenAI (leave empty to use mock AI)
OPENAI_API_KEY=

# File upload (local or cloudinary)
UPLOAD_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Company Info (used in AI system prompt)
COMPANY_NAME=BrickPro
COMPANY_PHONE=+91-9876543210
COMPANY_WHATSAPP=+919876543210
COMPANY_EMAIL=info@brickpro.com
COMPANY_ADDRESS=123 Brick Market, Industrial Area, City - 400001

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_CALLBACK_URL=http://localhost:5000/api/v1/customer/auth/google/callback